{
    "name": "fitodac/laravel-mercadopago",
    "description": "Mercado Pago integration package for Laravel with demo endpoints and reusable services.",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "mercadopago/dx-php": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Fitodac\\LaravelMercadoPago\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fitodac\\LaravelMercadoPago\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fitodac\\LaravelMercadoPago\\LaravelMercadoPagoServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
